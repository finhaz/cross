<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="cross.DbcView"
             xmlns:viewmodels="clr-namespace:cross.ViewModels"
             x:DataType="viewmodels:DbcViewModel">
      <!-- 整体布局：左侧按钮区  + 右侧DBC展示区 -->
    <!-- 页面绑定ViewModel -->
    <UserControl.DataContext>
        <viewmodels:DbcViewModel/>
    </UserControl.DataContext>

    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：加载DBC文件按钮 + 状态展示（绑定ViewModel属性） -->
        <Border Grid.Column="0" Background="#F5F5F5" CornerRadius="5" Margin="0,0,5,0">
            <StackPanel VerticalAlignment="Top" Margin="10">
                <Button x:Name="BtnLoadDbc" Content="加载DBC文件" Width="160" Height="40" 
                        FontSize="14" Background="#007ACC" Foreground="White"
                        Click="BtnLoadDbc_Click"/>
                <!-- ✅ 新增：进入AT指令模式按钮 -->
                <Button x:Name="BtnEnterATMode" Content="进入AT指令模式" Width="160" Height="36" Margin="0,10,0,0"
                FontSize="12" Background="#007ACC" Foreground="White"
                Click="BtnEnterATMode_Click"/>
                <!-- ✅ ✅ ✅ 新增：AT模块状态文本框【核心】绑定ViewModel的AtModuleStatus属性 -->
                <TextBlock x:Name="TxtAtStatus" 
                   Text="{Binding AtModuleStatus}" 
                   Margin="0,8,0,0" FontSize="11" 
                   Width="160" TextWrapping="Wrap"
                   Foreground="#007ACC"/>
                <TextBlock Margin="0,20,0,0" FontSize="12" Foreground="#333" Text="{Binding DbcLoadState}"/>
                <TextBlock Margin="0,10,0,0" FontSize="12" Foreground="#333" Text="{Binding FrameCountInfo}"/>

                <!-- ================ ✅ 只加这一块 最小改动 完美贴合 其他全不变 ================ -->
                <Border Margin="0,30,0,0" BorderBrush="#007ACC" BorderThickness="1" CornerRadius="3" Width="160">
                    <StackPanel Margin="5">
                        <TextBlock FontSize="12" FontWeight="Bold" Foreground="#007ACC" Text="CAN帧发送"/>
                        <!-- 选择要发送的帧 -->
                        <ComboBox x:Name="CbxSendFrame" Width="150" Height="30" Margin="0,10,0,0" FontSize="11"
                                  ItemsSource="{Binding DbcFrameList}"
                                  SelectedItem="{Binding SelectedSendFrame}"
                                  DisplayMemberBinding="{Binding FrameName}"/>
                        <!-- 发送按钮 -->
                        <Button x:Name="BtnSendCanFrame" Content="发送CAN帧" Width="150" Height="35" Margin="0,10,0,0"
                                FontSize="12" Background="#007ACC" Foreground="White"
                                Click="BtnSendCanFrame_Click"/>
                        <!-- 发送状态提示 -->
                        <TextBlock Margin="0,10,0,0" FontSize="11" Foreground="#007ACC" Text="{Binding SendStatus}"/>
                    </StackPanel>
                </Border>
                <!-- ================ ✅ 新增结束 ================ -->

            </StackPanel>
        </Border>

<!-- 右侧：DBC解析视图（绑定ViewModel的帧列表） -->
<Border Grid.Column="1" Background="White" CornerRadius="5" BorderBrush="#E0E0E0" BorderThickness="1">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding DbcFrameList}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Expander IsExpanded="True" Margin="0,5,0,0" FontSize="13" FontWeight="Bold">
                        <Expander.Header>
                            <MultiBinding StringFormat="{}{0} (十进制ID={1} | 十六进制ID=0x{1:X} | 长度={2}Byte)">
                                <Binding Path="FrameName"/>
                                <Binding Path="FrameId"/>
                                <Binding Path="DataLength"/>
                            </MultiBinding>
                        </Expander.Header>

                        <!-- 替换 DataGrid 的区域：使用 ListBox + 独立列头 -->
                        <Border Background="White" Padding="5">
                            <StackPanel>
                                <!-- 列头（固定） -->
                                <Border Background="#F0F0F0" Padding="5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="信号名称" FontWeight="Bold" Grid.Column="0" />
                                        <TextBlock Text="原始值" FontWeight="Bold" Grid.Column="1" />
                                        <TextBlock Text="物理值" FontWeight="Bold" Grid.Column="2" />
                                        <TextBlock Text="单位" FontWeight="Bold" Grid.Column="3" />
                                        <TextBlock Text="更新时间" FontWeight="Bold" Grid.Column="4" />
                                        <TextBlock Text="起始位" FontWeight="Bold" Grid.Column="5" />
                                        <TextBlock Text="位长" FontWeight="Bold" Grid.Column="6" />
                                    </Grid>
                                </Border>

                                <!-- 数据列表（支持滚动，可编辑） -->
                                <ListBox ItemsSource="{Binding Signals}" 
                                         Background="Transparent" 
                                         BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="5">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="180" />
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="80" />
                                                        <ColumnDefinition Width="150" />
                                                        <ColumnDefinition Width="80" />
                                                        <ColumnDefinition Width="80" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Text="{Binding SignalName}" 
                                                               Grid.Column="0" 
                                                               VerticalAlignment="Center" />

                                                    <!-- 原始值可编辑 -->
                                                    <TextBox Text="{Binding RawValue, UpdateSourceTrigger=PropertyChanged}" 
                                                             Grid.Column="1" 
                                                             VerticalAlignment="Center" />

                                                    <TextBlock Text="{Binding PhysicalValue}" 
                                                               Grid.Column="2" 
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding Unit}" 
                                                               Grid.Column="3" 
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding UpdateTime}" 
                                                               Grid.Column="4" 
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding StartBit}" 
                                                               Grid.Column="5" 
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding BitLength}" 
                                                               Grid.Column="6" 
                                                               VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>
                    </Expander>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</Border>
    </Grid>
</UserControl>
